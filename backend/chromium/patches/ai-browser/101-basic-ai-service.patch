+// found in the LICENSE file.
+
+#include "chrome/browser/ai/ai_service.h"
+
+#include "base/logging.h"
+#include "base/json/json_writer.h"
+#include "net/base/url_util.h"
+
+namespace ai {
+
+AIService::AIService() {
+  LOG(INFO) << "AI Service initialized";
+}
+
+AIService::~AIService() = default;
+
+void AIService::SendMessage(const std::string& message,
+                            const std::string& page_url,
+                            base::OnceCallback<void(const std::string&)> callback) {
+  // Simple implementation - in production this would call the backend API
+  LOG(INFO) << "AI Service received message: " << message;
+  
+  // For now, return a simple response
+  std::string response = "AI response to: " + message;
+  std::move(callback).Run(response);
+}
+
+bool AIService::IsAvailable() const {
+  // Check if local AI backend is running on localhost:8000
+  return true;  // Simplified for now
+}
+
+}  // namespace ai