--- /dev/null
+++ b/chrome/browser/ui/webui/side_panel/ai_chat/ai_chat_side_panel_ui_test.cc
@@ -0,0 +1,70 @@
+#include "chrome/browser/ui/webui/side_panel/ai_chat/ai_chat_side_panel_ui.h"
+
+#include "chrome/browser/ai/ai_service_factory.h"
+#include "chrome/test/base/testing_profile.h"
+#include "chrome/test/base/web_ui_browser_test.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/test/browser_test.h"
+#include "content/public/test/scoped_web_ui_controller_factory_registration.h"
+
+namespace {
+
+class TestAIChatSidePanelUIFactory : public content::WebUIControllerFactory {
+ public:
+  std::unique_ptr<content::WebUIController> CreateWebUIControllerForURL(
+      content::WebUI* web_ui,
+      const GURL& url) override {
+    if (url.host() == chrome::kChromeUIAIChatHost) {
+      return std::make_unique<AIChatSidePanelUI>(web_ui);
+    }
+    return nullptr;
+  }
+
+  content::WebUI::TypeID GetWebUIType(content::BrowserContext* browser_context,
+                                     const GURL& url) override {
+    if (url.host() == chrome::kChromeUIAIChatHost) {
+      return reinterpret_cast<content::WebUI::TypeID>(1);
+    }
+    return content::WebUI::kNoWebUI;
+  }
+
+  bool UseWebUIForURL(content::BrowserContext* browser_context,
+                     const GURL& url) override {
+    return url.host() == chrome::kChromeUIAIChatHost;
+  }
+};
+
+}  // namespace
+
+class AIChatSidePanelUITest : public WebUIBrowserTest {
+ public:
+  AIChatSidePanelUITest() = default;
+  ~AIChatSidePanelUITest() override = default;
+
+  void SetUpOnMainThread() override {
+    WebUIBrowserTest::SetUpOnMainThread();
+    factory_registration_ =
+        std::make_unique<content::ScopedWebUIControllerFactoryRegistration>(
+            &factory_, content::WebUIControllerFactory::GetInstance());
+  }
+
+  void TearDownOnMainThread() override {
+    factory_registration_.reset();
+    WebUIBrowserTest::TearDownOnMainThread();
+  }
+
+ protected:
+  TestAIChatSidePanelUIFactory factory_;
+  std::unique_ptr<content::ScopedWebUIControllerFactoryRegistration>
+      factory_registration_;
+};
+
+IN_PROC_BROWSER_TEST_F(AIChatSidePanelUITest, LoadAIChatUI) {
+  // Navigate to the AI Chat WebUI
+  GURL ai_chat_url(chrome::kChromeUIAIChatURL);
+  ASSERT_TRUE(NavigateToURL(ai_chat_url));
+  
+  // Verify the page loaded successfully
+  EXPECT_EQ(web_ui()->GetWebContents()->GetLastCommittedURL(), ai_chat_url);
+  
+  // Verify we have the correct WebUI controller
+  AIChatSidePanelUI* ai_chat_ui = 
+      static_cast<AIChatSidePanelUI*>(web_ui()->GetController());
+  ASSERT_NE(ai_chat_ui, nullptr);
+}