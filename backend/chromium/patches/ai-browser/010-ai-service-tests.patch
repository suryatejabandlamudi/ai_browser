+++ b/chrome/browser/ai/ai_service_factory_unittest.cc
@@ -0,0 +1,45 @@
+#include "chrome/browser/ai/ai_service_factory.h"
+#include "chrome/browser/ai/ai_service.h"
+
+#include "chrome/test/base/testing_profile.h"
+#include "content/public/test/browser_task_environment.h"
+#include "testing/gtest/include/gtest/gtest.h"
+
+namespace ai {
+
+class AIServiceFactoryTest : public testing::Test {
+ public:
+  AIServiceFactoryTest() = default;
+  ~AIServiceFactoryTest() override = default;
+
+  void SetUp() override {
+    profile_ = std::make_unique<TestingProfile>();
+  }
+
+ protected:
+  content::BrowserTaskEnvironment task_environment_;
+  std::unique_ptr<TestingProfile> profile_;
+};
+
+TEST_F(AIServiceFactoryTest, GetForProfile) {
+  AIService* service = AIServiceFactory::GetForProfile(profile_.get());
+  ASSERT_NE(service, nullptr);
+  
+  // Second call should return same instance
+  AIService* service2 = AIServiceFactory::GetForProfile(profile_.get());
+  EXPECT_EQ(service, service2);
+}
+
+TEST_F(AIServiceFactoryTest, OffTheRecordProfile) {
+  Profile* otr_profile = profile_->GetPrimaryOTRProfile(/*create_if_needed=*/true);
+  AIService* service = AIServiceFactory::GetForProfile(otr_profile);
+  EXPECT_EQ(service, nullptr);  // Should not create for OTR profiles
+}
+
+TEST_F(AIServiceFactoryTest, ServiceIsCreatedWithBrowserContext) {
+  AIServiceFactory* factory = AIServiceFactory::GetInstance();
+  EXPECT_TRUE(factory->ServiceIsCreatedWithBrowserContext());
+}
+
+}  // namespace ai