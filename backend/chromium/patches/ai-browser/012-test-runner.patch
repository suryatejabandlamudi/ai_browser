+#!/bin/bash
+"""
+Script to apply AI browser patches to Chromium source
+"""
+
+set -e
+
+SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
+PATCHES_DIR="$SCRIPT_DIR/../patches/ai-browser"
+CHROMIUM_SRC_DIR="$1"
+
+if [ -z "$CHROMIUM_SRC_DIR" ]; then
+    echo "Usage: $0 <chromium_src_directory>"
+    exit 1
+fi
+
+if [ ! -d "$CHROMIUM_SRC_DIR" ]; then
+    echo "Error: Chromium source directory does not exist: $CHROMIUM_SRC_DIR"
+    exit 1
+fi
+
+echo "🔧 Applying AI Browser patches to Chromium source..."
+echo "Source directory: $CHROMIUM_SRC_DIR"
+echo "Patches directory: $PATCHES_DIR"
+echo
+
+cd "$CHROMIUM_SRC_DIR"
+
+# Apply patches in order
+PATCHES=(
+    "001-ai-service-integration.patch"
+    "002-ai-sidepanel.patch" 
+    "003-local-ai-api.patch"
+    "004-privacy-first-features.patch"
+    "005-ai-powered-omnibox.patch"
+    "006-ai-service-implementation.patch"
+    "007-ai-chat-webui.patch"
+    "008-ai-chat-resources.patch"
+    "009-fix-missing-dependencies.patch"
+)
+
+for patch in "${PATCHES[@]}"; do
+    patch_file="$PATCHES_DIR/$patch"
+    if [ -f "$patch_file" ]; then
+        echo "📄 Applying patch: $patch"
+        if patch -p1 < "$patch_file"; then
+            echo "✅ Successfully applied: $patch"
+        else
+            echo "❌ Failed to apply: $patch"
+            echo "This may be normal if the patch was already applied."
+        fi
+    else
+        echo "⚠️ Patch file not found: $patch_file"
+    fi
+    echo
+done
+
+echo "🎉 Patch application complete!"
+echo "You can now build Chromium with AI browser features."
+echo "Use: autoninja -C out/Default chrome"