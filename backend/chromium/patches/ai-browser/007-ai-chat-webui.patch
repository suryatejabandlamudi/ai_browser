@@ -0,0 +1,85 @@
+#include "chrome/browser/ui/webui/side_panel/ai_chat/ai_chat_side_panel_ui.h"
+
+#include "chrome/browser/ai/ai_service_factory.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "chrome/grit/generated_resources.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "content/public/browser/web_ui_message_handler.h"
+
+namespace {
+
+class AIChatUIHandler : public content::WebUIMessageHandler {
+ public:
+  AIChatUIHandler() = default;
+  ~AIChatUIHandler() override = default;
+
+  void RegisterMessages() override {
+    web_ui()->RegisterDeprecatedMessageCallback(
+        "sendMessage",
+        base::BindRepeating(&AIChatUIHandler::HandleSendMessage,
+                           base::Unretained(this)));
+    web_ui()->RegisterDeprecatedMessageCallback(
+        "getPageContent",
+        base::BindRepeating(&AIChatUIHandler::HandleGetPageContent,
+                           base::Unretained(this)));
+  }
+
+ private:
+  void HandleSendMessage(const base::Value::List& args) {
+    if (args.size() < 2) return;
+    
+    const std::string& message = args[0].GetString();
+    const std::string& callback_id = args[1].GetString();
+    
+    Profile* profile = Profile::FromWebUI(web_ui());
+    ai::AIService* ai_service = ai::AIServiceFactory::GetForProfile(profile);
+    
+    if (!ai_service || !ai_service->IsConnected()) {
+      ResolveJavascriptCallback(
+          base::Value(callback_id),
+          base::Value("Error: AI service not available"));
+      return;
+    }
+    
+    // Get current page URL for context
+    content::WebContents* web_contents = web_ui()->GetWebContents();
+    std::string page_url = web_contents ? web_contents->GetLastCommittedURL().spec() : "";
+    
+    ai_service->SendChatMessage(
+        message, page_url,
+        base::BindOnce(&AIChatUIHandler::OnChatResponse,
+                       weak_factory_.GetWeakPtr(), callback_id));
+  }
+  
+  void HandleGetPageContent(const base::Value::List& args) {
+    if (args.empty()) return;
+    
+    const std::string& callback_id = args[0].GetString();
+    
+    // Get accessibility tree content from current page
+    content::WebContents* web_contents = web_ui()->GetWebContents();
+    if (web_contents) {
+      // Extract page title and URL for context
+      base::Value::Dict page_info;
+      page_info.Set("title", web_contents->GetTitle());
+      page_info.Set("url", web_contents->GetLastCommittedURL().spec());
+      
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(std::move(page_info)));
+    }
+  }
+  
+  void OnChatResponse(const std::string& callback_id, bool success, const std::string& response) {
+    ResolveJavascriptCallback(
+        base::Value(callback_id),
+        base::Value(success ? response : "Error: " + response));
+  }
+  
+  base::WeakPtrFactory<AIChatUIHandler> weak_factory_{this};
+};
+
+}  // namespace
+
+AIChatSidePanelUI::AIChatSidePanelUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  
+  // Create data source
+  content::WebUIDataSource* source = content::WebUIDataSource::Create(
+      chrome::kChromeUIAIChatHost);
+  
+  // Add HTML content
+  source->SetDefaultResource(IDR_AI_CHAT_SIDE_PANEL_HTML);
+  source->AddResourcePath("ai_chat_side_panel.js", IDR_AI_CHAT_SIDE_PANEL_JS);
+  source->AddResourcePath("ai_chat_side_panel.css", IDR_AI_CHAT_SIDE_PANEL_CSS);
+  
+  // Add strings
+  source->AddLocalizedString("aiChatTitle", IDS_AI_CHAT_TITLE);
+  source->AddLocalizedString("aiChatPlaceholder", IDS_AI_CHAT_PLACEHOLDER);
+  source->AddLocalizedString("aiChatSend", IDS_AI_CHAT_SEND);
+  
+  // Enable trusted types
+  source->DisableTrustedTypesCSP();
+  
+  content::WebUIDataSource::Add(Profile::FromWebUI(web_ui), source);
+  
+  // Add message handler
+  web_ui->AddMessageHandler(std::make_unique<AIChatUIHandler>());
+}
+
+AIChatSidePanelUI::~AIChatSidePanelUI() = default;
