+class AIChatSidePanel {
+  constructor() {
+    this.messageInput = document.getElementById('message-input');
+    this.sendButton = document.getElementById('send-button');
+    this.chatMessages = document.getElementById('chat-messages');
+    this.statusIndicator = document.getElementById('status-indicator');
+    this.statusText = document.getElementById('status-text');
+    this.contextInfo = document.getElementById('context-info');
+    
+    this.isConnected = false;
+    this.currentPageInfo = null;
+    
+    this.initializeEventListeners();
+    this.checkConnection();
+    this.loadPageContext();
+  }
+  
+  initializeEventListeners() {
+    this.sendButton.addEventListener('click', () => this.sendMessage());
+    
+    this.messageInput.addEventListener('keydown', (event) => {
+      if (event.key === 'Enter' && !event.shiftKey) {
+        event.preventDefault();
+        this.sendMessage();
+      }
+    });
+    
+    this.messageInput.addEventListener('input', () => {
+      this.updateSendButton();
+    });
+  }
+  
+  updateSendButton() {
+    const hasText = this.messageInput.value.trim().length > 0;
+    this.sendButton.disabled = !hasText || !this.isConnected;
+  }
+  
+  updateConnectionStatus(connected) {
+    this.isConnected = connected;
+    this.statusIndicator.className = connected ? 'connected' : '';
+    this.statusText.textContent = connected ? 'Connected to Local AI' : 'Disconnected';
+    this.updateSendButton();
+  }
+  
+  checkConnection() {
+    // For now, assume connected since we have the backend running
+    // In a real implementation, this would ping the AI service
+    setTimeout(() => {
+      this.updateConnectionStatus(true);
+    }, 1000);
+  }
+  
+  loadPageContext() {
+    chrome.tabs.query({active: true, currentWindow: true}, (tabs) => {
+      if (tabs[0]) {
+        this.currentPageInfo = {
+          title: tabs[0].title,
+          url: tabs[0].url
+        };
+        this.updateContextInfo();
+      }
+    });
+  }
+  
+  updateContextInfo() {
+    if (this.currentPageInfo) {
+      this.contextInfo.textContent = `Page: ${this.currentPageInfo.title}`;
+    }
+  }
+  
+  addMessage(content, type = 'ai') {
+    const messageDiv = document.createElement('div');
+    messageDiv.className = `message ${type}`;
+    messageDiv.textContent = content;
+    
+    this.chatMessages.appendChild(messageDiv);
+    this.chatMessages.scrollTop = this.chatMessages.scrollHeight;
+  }
+  
+  async sendMessage() {
+    const message = this.messageInput.value.trim();
+    if (!message || !this.isConnected) return;
+    
+    // Add user message
+    this.addMessage(message, 'user');
+    this.messageInput.value = '';
+    this.updateSendButton();
+    
+    // Show typing indicator
+    const typingDiv = document.createElement('div');
+    typingDiv.className = 'message ai typing';
+    typingDiv.textContent = 'AI is thinking...';
+    this.chatMessages.appendChild(typingDiv);
+    this.chatMessages.scrollTop = this.chatMessages.scrollHeight;
+    
+    try {
+      // Send message to AI service
+      const response = await new Promise((resolve) => {
+        chrome.webUIResponse('sendMessage', [message], (result) => {
+          resolve(result);
+        });
+      });
+      
+      // Remove typing indicator
+      this.chatMessages.removeChild(typingDiv);
+      
+      // Add AI response
+      this.addMessage(response, 'ai');
+      
+    } catch (error) {
+      // Remove typing indicator
+      this.chatMessages.removeChild(typingDiv);
+      
+      // Add error message
+      this.addMessage('Error: Unable to get AI response', 'error');
+    }
+  }
+}
+
+// Initialize when DOM is loaded
+document.addEventListener('DOMContentLoaded', () => {
+  new AIChatSidePanel();
+});
+
+// Export for testing
+window.AIChatSidePanel = AIChatSidePanel;