+bool OmniboxController::IsAIQuery(const std::u16string& text) const {
+  // Detect AI queries by common patterns
+  std::string text_utf8 = base::UTF16ToUTF8(text);
+  std::transform(text_utf8.begin(), text_utf8.end(), text_utf8.begin(), ::tolower);
+  
+  // AI query indicators
+  std::vector<std::string> ai_indicators = {
+    "what is", "how to", "explain", "summarize", "analyze", 
+    "help me", "can you", "tell me about", "search for",
+    "find information about", "research", "compare"
+  };
+  
+  for (const std::string& indicator : ai_indicators) {
+    if (text_utf8.find(indicator) != std::string::npos) {
+      return true;
+    }
+  }
+  
+  return text_utf8.length() > 20 && text_utf8.find('?') != std::string::npos;
+}
